# --- 1. 敏感配置文件 (绝对不能提交!) ---
.env
*.env

# --- 2. 虚拟环境 (太大且依赖本地系统，不提交) ---
nano_query_env/
venv/
env/

# --- 3. 数据库与本地数据 (根据情况，通常不提交真实数据) ---
# 如果你想忽略 data 文件夹下的所有 sqlite 数据库文件：
data/*.db
data/*.sqlite
data/*.sqlite3

# --- 4. Python 缓存文件 (运行时自动生成，不提交) ---
__pycache__/
*.py[cod]
*$py.class

# --- 5. IDE 配置文件 (PyCharm 生成的本地配置，不提交) ---
.idea/

# --- 6. macOS 系统垃圾文件 ---
.DS_Store


# LangGraph 本地缓存与快照
.langgraph_api/

# 本地数据库与记忆存储
data/memory/
*.db
*.db-shm
*.db-wal
